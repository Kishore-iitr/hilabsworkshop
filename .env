# =====================================================================
# CLINICAL AI EVALUATION SYSTEM — ENV CONFIG
# Copy this file to .env and fill in your credentials.
# =====================================================================

# ── OpenRouter (required) ─────────────────────────────────────────────
# Get your key at: https://openrouter.ai/keys
OPENROUTER_API_KEY=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
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_SITE_URL=http://localhost
OPENROUTER_SITE_NAME=ClinicalEval

# ── Active LLM model ──────────────────────────────────────────────────
# Leave blank to auto-select the first model in CANDIDATE_MODELS.
# Pin a specific model by uncommenting one of these:
#   LLM_MODEL=openai/gpt-4o-mini
#   LLM_MODEL=openai/gpt-4.1-mini
#   LLM_MODEL=google/gemini-2.0-flash-exp:free
#   LLM_MODEL=meta-llama/llama-3.3-70b-instruct:free
#LLM_MODEL=

# ── Candidate model list (comma-separated OpenRouter slugs) ───────────
# Add any model from https://openrouter.ai/models
# The evaluator auto-falls-back through this list on API errors.
CANDIDATE_MODELS=openai/gpt-4o-mini,openai/gpt-4.1-mini,google/gemini-2.0-flash-exp:free,meta-llama/llama-3.3-70b-instruct:free,mistralai/mistral-7b-instruct:free-exp:free,meta-llama/llama-3.3-70b-instruct:free:free,google/gemini-flash-1.5,meta-llama/llama-3.3-70b-instruct:free,meta-llama/llama-3.1-8b-instruct:free,mistralai/mistral-7b-instruct:free,microsoft/phi-3-mini-128k-instruct:free,qwen/qwen-2.5-72b-instruct:free

MAX_TOKENS=2048

# ── Embeddings ────────────────────────────────────────────────────────
EMBEDDING_PROVIDER=openrouter
EMBEDDING_MODEL=openai/text-embedding-3-small
EMBEDDING_DIM=1536

# ── Pinecone (required) ───────────────────────────────────────────────
PINECONE_API_KEY=pcsk_4vqukq_CwBrCgRU3k75w7hkQrfYRsRTg2piSA2v3e7ffx3LDPDYRgcrjwroXyCB9xfvGNd
PINECONE_INDEX_NAME=clinical-eval-chunks
PINECONE_ENVIRONMENT=us-east-1

# ── Chunking & processing ─────────────────────────────────────────────
CHUNK_SIZE=400
CHUNK_OVERLAP=80
BATCH_SIZE=5
